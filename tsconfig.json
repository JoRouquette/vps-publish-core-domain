{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2021",
    "lib": ["ES2021", "DOM"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "paths": {
      "@core-domain": ["./src/index.ts"],
      "@core-domain/*": ["./src/lib/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
